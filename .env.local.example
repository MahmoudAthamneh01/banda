# Environment Configuration Example
# Copy this file to .env.local and update with your values

# ==============================================================================
# SERVICE MODE
# ==============================================================================
# Set to 'true' for development with mock data (no backend needed)
# Set to 'false' for production with real API
NEXT_PUBLIC_USE_MOCK_SERVICES=true

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
# Backend API URL (used when USE_MOCK_SERVICES=false)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ==============================================================================
# AUTHENTICATION
# ==============================================================================
# JWT secret for token signing
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiration times
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==============================================================================
# DATABASE (Backend API)
# ==============================================================================
# PostgreSQL for relational data (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/bandachao

# MongoDB for product catalog
MONGODB_URI=mongodb://localhost:27017/bandachao

# Redis for caching and sessions
REDIS_URL=redis://localhost:6379

# ==============================================================================
# PAYMENT GATEWAYS
# ==============================================================================
# Alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key

# WeChat Pay
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-merchant-id
WECHAT_API_KEY=your-wechat-api-key

# ==============================================================================
# AI PROVIDERS
# ==============================================================================
# OpenAI for Cyber Wukong & other agents
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Local/Chinese AI alternatives
ZHIPU_API_KEY=your-zhipu-key
BAIDU_API_KEY=your-baidu-key

# ==============================================================================
# FILE STORAGE
# ==============================================================================
# AWS S3 or Aliyun OSS for file uploads
S3_BUCKET=bandachao-uploads
S3_REGION=cn-north-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ==============================================================================
# NOTIFICATIONS
# ==============================================================================
# Email service (Aliyun DirectMail or SendGrid)
EMAIL_FROM=noreply@bandachao.com
ALIYUN_EMAIL_ACCESS_KEY=your-email-access-key
ALIYUN_EMAIL_SECRET_KEY=your-email-secret-key

# SMS service (Aliyun SMS)
ALIYUN_SMS_ACCESS_KEY=your-sms-access-key
ALIYUN_SMS_SECRET_KEY=your-sms-secret-key
ALIYUN_SMS_SIGN_NAME=带拿潮

# ==============================================================================
# KYC/VERIFICATION
# ==============================================================================
# Face++ or similar Chinese KYC provider
KYC_PROVIDER_URL=https://api-cn.faceplusplus.com
KYC_API_KEY=your-kyc-api-key
KYC_API_SECRET=your-kyc-api-secret

# ==============================================================================
# MONITORING & LOGGING
# ==============================================================================
# Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn

# Log level
LOG_LEVEL=info

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Enable/disable specific features
FEATURE_RFQ_ENABLED=true
FEATURE_JUSTICE_SYSTEM_ENABLED=true
FEATURE_AI_CHAT_ENABLED=true
FEATURE_INVESTMENT_ENABLED=true
FEATURE_REFERRAL_REWARDS_ENABLED=true

# ==============================================================================
# SOVEREIGN SPLIT CONFIGURATION
# ==============================================================================
# Platform fee rate (5.5% = 0.055)
SOVEREIGN_FEE_RATE=0.055

# Fund allocation percentages (must sum to 1.0)
HEDGE_FUND_SHARE=0.55
RD_FUND_SHARE=0.15
EXPANSION_FUND_SHARE=0.15
SALARIES_FUND_SHARE=0.15
