# Database Configuration (Required)
# Use localhost:5433 when running the repository Docker Compose database.
# Use localhost:5432 if you point at a native local PostgreSQL service.
DATABASE_URL="postgresql://banda:password@localhost:5433/banda_db?schema=public"

# Server Configuration
NODE_ENV=development
PORT=3001

# JWT Configuration (Required)
# Generate a 32+ byte random secret for every environment.
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# AI provider
AI_PROVIDER="local"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
