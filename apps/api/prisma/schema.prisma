generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  BUYER
  MAKER
  SERVICE_PROVIDER
  INVESTOR
  ADMIN
  OWNER
  AMBASSADOR
}

enum UserTier {
  STANDARD
  STUDENT_AMBASSADOR
  VIP
}

enum SocialTier {
  CUB
  TIGER
  DRAGON
}

enum WalletType {
  FIAT
  POINTS
  LOCKED
  ESCROW
  FUND_REVENUE
  FUND_HEDGE
  FUND_RD
  FUND_EXPANSION
  SYSTEM
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  ORDER_PAYMENT
  RFQ_ESCROW
  RFQ_RELEASE
  REFERRAL_REWARD
  INVESTMENT
  SOVEREIGN_SPLIT
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum ReferralStatus {
  ACTIVE
  INACTIVE
  FLAGGED
}

enum ReferralRewardType {
  SIGNUP
  FIRST_ORDER
  COMMISSION
  CAPITAL_INJECTION
}

enum AIConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AVATAR
  PRODUCT
}

enum RFQStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  QUOTED
  ACCEPTED
  REJECTED
}

enum RfqBidStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  password      String
  username      String?     @unique
  phone         String?     @unique
  role          Role        @default(USER)
  tier          UserTier    @default(STANDARD)
  socialTier    SocialTier  @default(CUB)
  vipUntil      DateTime?
  vipIsLifetime Boolean     @default(false)
  referralCode  String      @unique @default(uuid())

  profile         Profile?
  wallets         Wallet[]
  actions         AuditLog[]
  rfqs            Rfq[]
  rfqBids         RfqBid[]         @relation("RfqBidMaker")
  products        Product[]        @relation("MakerProducts")
  buyerOrders     Order[]          @relation("BuyerOrders")
  makerOrders     Order[]          @relation("MakerOrders")
  transactions    Transaction[]
  referralsMade   Referral[]       @relation("ReferralsMade")
  referredBy      Referral?        @relation("ReferralReferee")
  aiConversations AIConversation[]
  media           Media[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([tier])
}

model Profile {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  bio         String?
  avatarUrl   String?
  locale      String  @default("en")
  country     String?
  city        String?
  kycStatus   String  @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wallet {
  id       String     @id @default(uuid())
  userId   String?
  user     User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     WalletType @default(FIAT)
  balance  Decimal    @default(0.0) @db.Decimal(18, 2)
  currency String     @default("CNY")

  ledgerEntries LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type, currency])
  @@index([type])
}

model Product {
  id          String  @id @default(uuid())
  makerId     String?
  maker       User?   @relation("MakerProducts", fields: [makerId], references: [id], onDelete: SetNull)
  sku         String  @unique
  name        String
  description String?
  price       Decimal @db.Decimal(18, 2)
  currency    String  @default("CNY")
  category    String?
  stock       Int     @default(0)
  status      String  @default("DRAFT")
  metadata    Json?

  media      Media[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([makerId])
  @@index([category])
  @@index([status])
}

model Order {
  id                String      @id @default(uuid())
  buyerId           String
  buyer             User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  makerId           String?
  maker             User?       @relation("MakerOrders", fields: [makerId], references: [id], onDelete: SetNull)
  status            OrderStatus @default(DRAFT)
  amountSubtotal    Decimal     @default(0.0) @db.Decimal(18, 2)
  amountTotal       Decimal     @default(0.0) @db.Decimal(18, 2)
  platformFeeRate   Decimal     @default(0.10) @db.Decimal(5, 4)
  platformFeeAmount Decimal     @default(0.0) @db.Decimal(18, 2)
  referralAmount    Decimal     @default(0.0) @db.Decimal(18, 2)
  currency          String      @default("CNY")
  metadata          Json?

  items           OrderItem[]
  transactions    Transaction[]
  referralRewards ReferralReward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([makerId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku       String?
  name      String
  quantity  Int
  unitPrice Decimal  @db.Decimal(18, 2)
  total     Decimal  @db.Decimal(18, 2)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderId     String?
  order       Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  referenceId String?
  amount      Decimal           @default(0.0) @db.Decimal(18, 2)
  currency    String            @default("CNY")
  metadata    Json?

  ledgerEntries   LedgerEntry[]
  referralRewards ReferralReward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([type])
  @@index([status])
  @@index([referenceId])
}

model LedgerEntry {
  id            String          @id @default(uuid())
  transactionId String
  transaction   Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  walletId      String
  wallet        Wallet          @relation(fields: [walletId], references: [id])
  direction     LedgerDirection
  amount        Decimal         @db.Decimal(18, 2)
  currency      String          @default("CNY")
  reasonCode    String
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([walletId])
  @@index([reasonCode])
}

model Referral {
  id         String         @id @default(uuid())
  referrerId String
  referrer   User           @relation("ReferralsMade", fields: [referrerId], references: [id])
  refereeId  String         @unique
  referee    User           @relation("ReferralReferee", fields: [refereeId], references: [id])
  code       String
  status     ReferralStatus @default(ACTIVE)

  rewards ReferralReward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([referrerId, refereeId])
  @@index([referrerId])
  @@index([code])
}

model ReferralReward {
  id            String             @id @default(uuid())
  referralId    String
  referral      Referral           @relation(fields: [referralId], references: [id], onDelete: Cascade)
  orderId       String?
  order         Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  transactionId String?
  transaction   Transaction?       @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  level         Int                @default(1)
  type          ReferralRewardType
  amount        Decimal            @db.Decimal(18, 2)
  currency      String             @default("CNY")
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([referralId])
  @@index([orderId])
  @@index([transactionId])
}

model AIConversation {
  id       String               @id @default(uuid())
  userId   String?
  user     User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider String               @default("local")
  model    String?
  status   AIConversationStatus @default(OPEN)
  title    String?
  metadata Json?

  messages AIMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  tokens         Int?

  createdAt DateTime @default(now())

  @@index([conversationId])
}

model Media {
  id        String    @id @default(uuid())
  ownerId   String?
  owner     User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  productId String?
  product   Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      MediaType
  url       String
  alt       String?
  provider  String    @default("local")
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([productId])
  @@index([type])
}

model AuditLog {
  id                String  @id @default(uuid())
  userId            String?
  user              User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action            String
  resource          String
  ip                String?
  deviceFingerprint String?
  legalConsent      Boolean @default(false)
  metadata          Json?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([resource])
}

model Rfq {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  status RFQStatus @default(DRAFT)

  productName String
  description String?
  category    String?
  targetPrice Decimal? @db.Decimal(18, 2)
  quantity    Int
  deadline    DateTime?

  sourceUrl String?
  sourceSku String?

  bids RfqBid[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model RfqBid {
  id           String       @id @default(uuid())
  rfqId        String
  rfq          Rfq          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  makerId      String
  maker        User         @relation("RfqBidMaker", fields: [makerId], references: [id])
  pricePerUnit Decimal      @db.Decimal(18, 2)
  totalPrice   Decimal      @db.Decimal(18, 2)
  deliveryDays Int
  message      String?
  status       RfqBidStatus @default(SUBMITTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfqId])
  @@index([makerId])
  @@index([status])
}
