{
    "name": "api",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsx watch src/server.ts",
        "start": "prisma generate --schema prisma/schema.prisma && node dist/server.js",
        "lint": "tsc --noEmit",
        "typecheck": "tsc --noEmit",
        "test": "node -e \"console.log('No API tests yet')\"",
        "prisma:generate": "prisma generate --schema prisma/schema.prisma",
        "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
        "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
        "prisma:deploy:production": "node scripts/prisma-deploy-production.js",
        "prisma:seed": "prisma db seed --schema prisma/schema.prisma",
        "accounts:ensure": "prisma generate --schema prisma/schema.prisma && node dist/scripts/ensure-login-accounts.js",
        "accounts:ensure:dev": "tsx src/scripts/ensure-login-accounts.ts"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "zod": "^3.22.4",
        "bcryptjs": "^2.4.3",
        "jsonwebtoken": "^9.0.2",
        "@prisma/client": "^5.22.0",
        "prisma": "^5.22.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "tsx": "^4.6.2",
        "typescript": "^5.3.3",
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.5"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}
